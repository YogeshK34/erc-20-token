    {
      "id": "yiwoIefBVdxTGtRXyyjaL",
      "type": "text",
      "x": 299.40774403805585,
      "y": 7564.4586808155655,
      "width": 529.93701171875,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0dN",
      "roundness": null,
      "seed": 1582747914,
      "version": 1294,
      "versionNonce": 1582082410,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783161346429,
      "link": null,
      "locked": false,
      "text": "1. Local blockchain: less accepting time & no Test Eth issues \n2. Mainnet forks: I can fork mainnets & can test out contracts \n    with real deployed contracts \n3. Deployment through Code: I can write a script to do a \n    factory pattern instead of Remix's GUI \n4. Version Control: it's all there files -> tests, scripts, etc, not \n    half-baked version like Remix's FS \n5. Dependency mgmt: real deps not any abstractions \n6. Verification & Gas reporting is Automated: I can run a single \n    command to run Etherscans check instead of copy pasting code \n    & gas usage tables is provided out of the box.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Local blockchain: less accepting time & no Test Eth issues \n2. Mainnet forks: I can fork mainnets & can test out contracts \n    with real deployed contracts \n3. Deployment through Code: I can write a script to do a \n    factory pattern instead of Remix's GUI \n4. Version Control: it's all there files -> tests, scripts, etc, not \n    half-baked version like Remix's FS \n5. Dependency mgmt: real deps not any abstractions \n6. Verification & Gas reporting is Automated: I can run a single \n    command to run Etherscans check instead of copy pasting code \n    & gas usage tables is provided out of the box.",
      "autoResize": true,
      "lineHeight": 1.25
    },
